; https://github.com/tldr-pages/tldr/blob/master/pages/common/edit.md

% edit, common

# Open a file
edit <path_to_file>

# Search for a pattern
<Ctrl f><pattern><Enter>

# Find and replace a pattern
<Ctrl r><pattern><Enter>

# Copy text
<Ctrl c>

# Paste text
<Ctrl v>

# Open the File menu
<Alt f>

# Quit
<Ctrl q>
