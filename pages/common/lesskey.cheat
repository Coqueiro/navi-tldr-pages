; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/lesskey.md

% lesskey, common

# Compile key bindings from a source file
lesskey <path_to_lesskey_file>

# Compile key bindings and write to a specific output file
lesskey <__o___output_> <path_to_output> <path_to_lesskey_file>

# Display version
lesskey <__V___version_>
