; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/xml-escape.md

% xml-escape, common

# Escape special XML characters in a string
xml <_esc_escape_> "<_a1_>"

# Escape special XML characters from `stdin`
echo "<_a1_>" | xml <_esc_escape_>

# Display help
xml <_esc_escape_> --help
