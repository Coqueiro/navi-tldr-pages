; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/llm.md

% llm, common

# Set up an OpenAI API Key
llm keys set openai

# Run a prompt
llm "{{Ten fun names for a pet pelican}}"

# Run a system prompt against a file
cat <path_to_file_py> | llm <__s___system_> "{{Explain this code}}"

# Install packages from PyPI into the same environment as LLM
llm install {{package1 package2 ...}}

# Download and run a prompt against a model
llm <__m___model_> <orca_mini_3b_gguf2_q4_0> "{{What is the capital of France?}}"

# Create a system prompt and save it with a template name
llm <__s___system_> '{{You are a sentient cheesecake}}' --save <sentient_cheesecake>

# Have an interactive chat with a specific model using a specific template
llm chat <__m___model_> <chatgpt> <__t___template_> <sentient_cheesecake>
