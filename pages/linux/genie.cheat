; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/genie.md

% genie, linux

# Initialize the bottle (run once, at start)
genie <__i___initialize_>

# Run a login shell inside the bottle
genie <__s___shell_>

# Run a specified command inside the bottle
genie <__c___command_> <command>
