; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/msgfmt.md

% msgfmt, common

# Compile a file to `messages.mo`
msgfmt <file_po>

# Convert a `.po` file to a `.mo` file
msgfmt <path_to_file_po> <__o___output_file_> <path_to_file_mo>

# Display help
msgfmt <__h___help_>
