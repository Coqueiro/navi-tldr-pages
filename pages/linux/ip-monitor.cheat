; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/ip-monitor.md

% ip-monitor, linux

# Monitor the whole network for state changes
ip <_mo_monitor_>

# Specify the type to monitor
ip <_mo_monitor_> <link_address_route_neigh_rule_maddress____>

# Replay an event file (can be generated with `rtmon`)
ip <_mo_monitor_> <_f_file_> <path_to_file>
