; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/nmcli-radio.md

% nmcli-radio, linux

# Show status of Wi-Fi
nmcli <_r_radio_> <_w_wifi_>

# Turn Wi-Fi on or off
nmcli <_r_radio_> <_w_wifi_> <on_off>

# Show status of WWAN
nmcli <_r_radio_> <_ww_wwan_>

# Turn WWAN on or off
nmcli <_r_radio_> <_ww_wwan_> <on_off>

# Show status of both switches
nmcli <_r_radio_>

# Turn both switches on or off
nmcli <_r_radio_> <_a_all_> <on_off>
