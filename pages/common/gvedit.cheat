; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/gvedit.md

% gvedit, common

# Open a Graphviz file in the editor
gvedit <path_to_graph_gv>

# [s]cale coordinates from points to inches (useful for layouts generated by Graphviz tools)
gvedit -s <path_to_graph_gv>

# Enable [v]erbose mode
gvedit -v <path_to_graph_gv>

# Display help
gvedit -?
