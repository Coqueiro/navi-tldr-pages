; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/biber.md

% biber, common

# Generate bibliography data using a BibLaTeX Control File
biber <path_to_file_bcf>

# Generate bibliography data using a configuration file
biber <path_to_file_bcf> <__g___configfile_> <path_to_config_file>

# Enable debugging
biber <path_to_file_bcf> <__D___debug_>
