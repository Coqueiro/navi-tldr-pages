; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/krdc.md

% krdc, linux

# Start KRDC
krdc

# Automatically connect to a host with the current username using VNC
krdc <remote_host>

# Specify the protocol and username used to connect to a host
krdc <vnc_rdp>://<username>@<remote_host>

# Start the connection in fullscreen mode
krdc <rdp___username_ip_address> --fullscreen
