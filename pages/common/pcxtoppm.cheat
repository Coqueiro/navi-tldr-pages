; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pcxtoppm.md

% pcxtoppm, common

# Convert a PCX file to a PPM image
pcxtoppm <path_to_file_pcx> > <path_to_file_ppm>

# Use a predefined standard palette even if the PCX file provides one
pcxtoppm <__s__stdpalette_> <path_to_file_pcx> > <path_to_file_ppm>

# Print information on the PCX header to `stdout`
pcxtoppm <__verb__verbose_> <path_to_file_pcx> > <path_to_file_ppm>
