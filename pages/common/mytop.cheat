; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/mytop.md

% mytop, common

# Start `mytop`
mytop

# Connect with a specified username and password
mytop <__u__user_> <user> <__p__password_> <password>

# Connect with a specified username (the user will be prompted for a password)
mytop <__u__user_> <user> -prompt

# Do not show any idle (sleeping) threads
mytop <__u__user_> <user> <__p__password_> <password> --noidle
