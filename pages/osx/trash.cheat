; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/osx/trash.md

% trash, osx

# Move a file to the trash
trash <path_to_file>

# Move multiple items or directories to the trash
trash {{path/to/file_or_directory1 path/to/file_or_directory2 ...}}

# Move files to the trash with verbose output
trash <__v___verbose_> {{path/to/file1 path/to/file2 ...}}

# Display help
trash <__h___help_>
