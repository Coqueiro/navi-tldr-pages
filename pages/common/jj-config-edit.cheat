; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/jj-config-edit.md

% jj-config-edit, common

# Start an editor on the user-level config file
jj config <_e_edit_> --user

# Start an editor on the repo-level config file
jj config <_e_edit_> --repo

# Start an editor on the workspace-level config file
jj config <_e_edit_> --workspace
