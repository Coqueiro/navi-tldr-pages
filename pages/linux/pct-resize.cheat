; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/pct-resize.md

% pct-resize, linux

# Resize the container size to 20GB
pct <_resi_resize_> <100> rootfs 20G

# Add 10GB to the container storage
pct <_resi_resize_> <100> rootfs +10G

# Resize a mounted volume
pct <_resi_resize_> <100> mp<0> <_10G>
