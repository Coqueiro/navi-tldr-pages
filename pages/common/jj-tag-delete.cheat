; https://github.com/tldr-pages/tldr/blob/master/pages/common/jj-tag-delete.md

% jj-tag-delete, common

# Delete a tag
jj tag <_d_delete_> <tag_name>

# Delete multiple tags
jj tag <_d_delete_> {{tag1 tag2 ...}}

# Delete tags matching a glob pattern
jj tag <_d_delete_> "<glob_v1__>"

# Delete tags matching a substring pattern
jj tag <_d_delete_> "<substring_release>"

# Delete a tag by exact name
jj tag <_d_delete_> "<exact_v1_0_0>"
