; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/osx/mole.md

% mole, osx

# Open the main menu
mole

# Free up disk space
mole clean

# Preview cleanup without making changes
mole clean --dry-run

# Remove apps completely
mole uninstall

# Check and maintain system
mole optimize

# Explore disk usage
mole analyze

# Monitor system health
mole status

# Remove old project artifacts
mole purge
