; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/systemctl-switch-root.md

% systemctl-switch-root, linux

# Switch to a new root filesystem and execute its default init system
systemctl switch-root <path_to_new_root>

# Switch to a new root filesystem and run a specific init binary
systemctl switch-root <path_to_new_root> <_sbin_init>

# Switch to a new root filesystem with verbose output
systemctl switch-root <path_to_new_root> <__v___verbose_>
