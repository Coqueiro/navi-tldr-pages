; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pdfunite.md

% pdfunite, common

# Merge multiple PDF files into a single one
pdfunite {{path/to/file1.pdf path/to/file2.pdf ...}} <path_to_merged_output_pdf>

# Merge a directory of PDFs into a single file
pdfunite <path_to_directory___pdf> <path_to_merged_output_pdf>
