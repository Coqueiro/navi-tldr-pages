; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/x-tping.md

% x-tping, common

# Ping a host on default port 80 with verbose mode
x tping <host>

# Ping a host with specific port
x tping <host>:<port>

# Show results as a heatmap
x tping <__m___heatmap_> <host>

# Show results as a bar graph
x tping <__b___bar_> <host>:<port>

# Output in raw data mode
x tping <__r___raw_> <host>

# Output in a specific format
x tping <__csv___tsv> <host>
