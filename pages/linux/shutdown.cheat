; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/shutdown.md

% shutdown, linux

# Power off ([h]alt) immediately
shutdown -h now

# Reboot immediately
shutdown <__r___reboot_> now

# Reboot in 5 minutes
shutdown <__r___reboot_> +<5> &

# Shutdown at 1:00 pm (Uses 24h clock)
shutdown -h 13:00

# [c]ancel a pending shutdown/reboot operation
shutdown -c
