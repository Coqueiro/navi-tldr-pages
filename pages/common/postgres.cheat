; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/postgres.md

% postgres, common

# Start the server on a specific port (defaults to 5432)
postgres -p <5433>

# Set a runtime parameter (short form)
postgres -c <shared_buffers_128MB>

# Set a runtime parameter (long form)
postgres --<shared_buffers>=<128MB>

# Start in single-user mode for a specific database (defaults to the user name)
postgres --single -D <path_to_datadir> <my_database>
