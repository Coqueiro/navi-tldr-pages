; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/lvmsar.md

% lvmsar, linux

# Run the legacy reporter (LVM1 systems only)
lvmsar

# Report I/O statistics for a device using device-mapper stats
dmstats report <_dev_mapper_device>

# List statistics regions for a device
dmstats list <_dev_mapper_device>
