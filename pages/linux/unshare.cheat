; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/unshare.md

% unshare, linux

# Execute a command without sharing access to connected networks
unshare <__n___net_> <command> <command_arguments>

# Execute a command as a child process without sharing mounts, processes, or networks
unshare <__m___mount_> <__i___pid_> <__n___net_> <__f___fork_> <command> <command_arguments>
