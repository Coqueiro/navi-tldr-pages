; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/qemu-system-riscv64.md

% qemu-system-riscv64, common

# Boot a kernel emulating `riscv64` architecture
qemu-system-riscv64 <__M__machine_> virt -bios none -kernel <kernel_elf> -nographic

# List supported machine types
qemu-system-riscv64 <__M__machine_> help

# Exit non-graphical QEMU
<Ctrl a><x>
