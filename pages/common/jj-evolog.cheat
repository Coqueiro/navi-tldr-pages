; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/jj-evolog.md

% jj-evolog, common

# Show how a revision has evolved over time
jj evolog <__r___revisions_> <revsets>

# Show diff statistics in the evolution log
jj evolog <__r___revisions_> <revsets> --stat

# Show summary of each change in the evolution log
jj evolog <__r___revisions_> <revsets> <__s___summary_>
