; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/xwdtopnm.md

% xwdtopnm, common

# Convert a XWD image file to PBM
xwdtopnm <path_to_input_file_xwd> > <path_to_output_file_pnm>

# Display information about the conversion process
xwdtopnm <__verb__verbose_> <path_to_input_file_xwd> > <path_to_output_file_pnm>

# Display the contents of the X11 header of the input file
xwdtopnm <__h__headerdump_> <path_to_input_file_xwd> > <path_to_output_file_pnm>
