; https://github.com/tldr-pages/tldr/blob/master/pages/common/tidy.md

% tidy, common

# Pretty print an HTML file
tidy <path_to_file_html>

# Enable indentation, wrapping lines in 100, saving to `output.html`
tidy <__i___indent_> y <__w___wrap_> 100 <__o__output_> <path_to_output_html> <path_to_file_html>

# Modify an HTML file in-place using a configuration file
tidy -config <path_to_configuration> <__m__modify_> <path_to_file_html>
