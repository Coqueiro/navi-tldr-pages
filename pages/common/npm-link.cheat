; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/npm-link.md

% npm-link, common

# Symlink the current package globally
npm <_ln_link_>

# Link a globally linked package into another project's `node_modules`
npm <_ln_link_> <package_name>

# Unlink a package from the current project
npm <_r_unlink_> <package_name>
