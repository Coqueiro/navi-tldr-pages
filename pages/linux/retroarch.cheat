; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/retroarch.md

% retroarch, linux

# Start in the menu mode
retroarch

# Start in full screen mode
retroarch <__f___fullscreen_>

# List all compiled features
retroarch --features

# Set the path of a configuration file
retroarch <__c___config_> <path_to_config_file>

# Display help
retroarch <__h___help_>

# Display version
retroarch --version
