; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/macptopbm.md

% macptopbm, common

# Convert a MacPaint file into a PGM image
macptopbm <path_to_file_macp> > <path_to_output_pbm>

# Skip over `n` bytes when reading the file
macptopbm <__e__extraskip_> <n> > <path_to_output_pbm>

# Suppress all informational messages
macptopbm <__q__quiet_> > <path_to_output_pbm>

# Display version
macptopbm <__v__version_>
