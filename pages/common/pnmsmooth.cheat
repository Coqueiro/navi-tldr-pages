; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pnmsmooth.md

% pnmsmooth, common

# Smooth out a PNM image using a convolution matrix of size 3x3
pnmsmooth <path_to_input_pnm> > <path_to_output_pnm>

# Smooth out a PNM image using a convolution matrix of size width times height
pnmsmooth <__w__width_> <width> <__h__height_> <height> <path_to_input_pnm> > <path_to_output_pnm>
