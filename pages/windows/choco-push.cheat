; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/windows/choco-push.md

% choco-push, windows

# Push a compiled `.nupkg` to the specified feed
choco push <__s___source_> <https___push_chocolatey_org_>

# Push a compiled `.nupkg` to the specified feed with a timeout in seconds (default is 2700)
choco push <__s___source_> <https___push_chocolatey_org_> <___timeout___execution_timeout_> <500>
