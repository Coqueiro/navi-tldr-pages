; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/docker-context.md

% docker-context, common

# Create a context using a specific Docker endpoint
docker context create <context_name> --docker "host=<tcp___remote_host_2375>"

# Create a context based on the `$DOCKER_HOST` environment variable
docker context create <context_name>

# Switch to a context
docker context use <context_name>

# List all contexts
docker context ls
