; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/iw-reg.md

% iw-reg, linux

# Display the current regulatory domain
iw reg get

# Set the regulatory domain according to ISO 3166-1 alpha-2
sudo iw reg set <US_JP_FI____>

# Reload the kernel's regulatory database
sudo iw reg reload
