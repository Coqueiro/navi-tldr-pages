; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/ppmdist.md

% ppmdist, common

# Produce a grayscale version of the specified PPM image
ppmdist <path_to_input_ppm> > <path_to_output_pgm>

# Use the specified method to map colors to graylevels
ppmdist -<frequency_intensity> <path_to_input_ppm> > <path_to_output_pgm>
