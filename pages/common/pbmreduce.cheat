; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pbmreduce.md

% pbmreduce, common

# Reduce the specified image by the specified factor
pbmreduce <n> <path_to_image_pbm> > <path_to_output_pbm>

# Use simple thresholding when reducing
pbmreduce <__t__threshold_> <n> <path_to_image_pbm> > <path_to_output_pbm>

# Use the specified threshold for all quantizations
pbmreduce <__va__value_> <0_6> <n> <path_to_image_pbm> > <path_to_output_pbm>
