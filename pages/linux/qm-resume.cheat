; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/qm-resume.md

% qm-resume, linux

# Resume a specific virtual machine
qm <_resu_resume_> <100>

# Resume a specific virtual machine ignoring locks (requires root)
sudo qm <_resu_resume_> <100> --skiplock true
