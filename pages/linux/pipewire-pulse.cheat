; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/pipewire-pulse.md

% pipewire-pulse, linux

# Start the daemon with default settings
pipewire-pulse

# Start the daemon with a specific configuration file
pipewire-pulse <__c___config_> <path_to_pipewire_pulse_conf>

# Increase the verbosity level (use multiple times for more verbosity, e.g. `-vvv`)
pipewire-pulse <__v___verbose_>

# Display help
pipewire-pulse <__h___help_>
