% ticketconverter.py, common

# Convert kirbi to ccache
ticketConverter.py <path_to_ticket_kirbi> <path_to_ticket_ccache>

# Convert ccache to kirbi
ticketConverter.py <path_to_ticket_ccache> <path_to_ticket_kirbi>
