; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/hg-update.md

% hg-update, common

# Update to the tip of the current branch
hg update

# Update to the specified revision
hg update <__r___rev_> <revision>

# Update and discard uncommitted changes
hg update <__C___clean_>

# Update to the last commit matching a specified date
hg update <__d___date_> <dd_mm_yyyy>
