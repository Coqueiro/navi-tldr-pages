; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/ppmtolj.md

% ppmtolj, common

# Convert a PPM file to an HP LaserJet PCL 5 Color file
ppmtolj <path_to_input_ppm> > <path_to_output_lj>

# Apply a gamma correction using the specified gamma value
ppmtolj <__g__gamma_> <gamma> <path_to_input_ppm> > <path_to_output_lj>

# Specify the required resolution
ppmtolj <__r__resolution_> <75_100_150_300_600> <path_to_input_ppm> > <path_to_output_lj>
