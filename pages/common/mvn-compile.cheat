; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/mvn-compile.md

% mvn-compile, common

# Compile the project's source code
mvn compile

# Clean compiled files and recompile
mvn clean compile

# Compile a specific module in a multi-module project
mvn compile <__pl___projects_> <module_name>

# Skip tests while compiling
mvn compile <__D___define_> skipTests
