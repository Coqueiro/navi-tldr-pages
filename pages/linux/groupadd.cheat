; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/groupadd.md

% groupadd, linux

# Create a new group
sudo groupadd <group_name>

# Create a new system group
sudo groupadd <__r___system_> <group_name>

# Create a new group with the specific groupid
sudo groupadd <__g___gid_> <id> <group_name>
