; https://github.com/tldr-pages/tldr/blob/master/pages/common/pamarith.md

% pamarith, common

# Apply the specified binary function pixel-wise on the two specified images (which must be of the same size)
pamarith -<add_subtract_multiply_divide_difference_minimum_maximum____> <path_to_image1_pam_pbm_pgm_ppm> <path_to_image2_pam_pbm_pgm_ppm>
