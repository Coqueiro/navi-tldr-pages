; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/tmpmail.md

% tmpmail, common

# Create a temporary inbox
tmpmail <__g___generate_>

# List messages and their numeric ID
tmpmail

# Display the most recent received email
tmpmail <__r___recent_>

# Open a specific message
tmpmail <email_id>

# View email as raw text without HTML tags
tmpmail <__t___text_>

# Open email with a specific browser (default is w3m)
tmpmail <__b___browser_> <browser>
