; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/twm.md

% twm, common

# Connect to the default X server
twm

# Connect to a specific X server
twm <__d__display_> <display>

# Only manage the default screen
twm <__s__single_>

# Use a specific startup file
twm <__f__file_> <path_to_file>

# Enable verbose mode and print unexpected errors in X
twm <__v__verbose_>
