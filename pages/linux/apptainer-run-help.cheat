; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/apptainer-run-help.md

% apptainer-run-help, linux

# Display help for a container
apptainer run-help <path_to_image_sif>

# Display help for a specific app within a container
apptainer run-help --app <app_name> <path_to_image_sif>

# Display help
apptainer run-help <__h___help_>
