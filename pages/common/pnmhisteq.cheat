; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pnmhisteq.md

% pnmhisteq, common

# Increase the contrast of a PNM image using histogram equalization
pnmhisteq <path_to_input_pnm> > <path_to_output_pnm>

# Only modify grey pixels
pnmhisteq {{[-g|-grey]}} <path_to_input_pnm> > <path_to_output_pnm>

# Do not include black or white pixels in the histogram equalization
pnmhisteq -no<black_white> <path_to_input_pnm> > <path_to_output_pnm>
