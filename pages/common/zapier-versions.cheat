; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/zapier-versions.md

% zapier-versions, common

# List the versions for an integration
zapier versions

# Include deprecated versions
zapier versions <__a___all_>

# Display additional debug output
zapier versions <__d___debug_>

# List the versions with a different output structure
zapier versions <__f___format_> <plain_json_raw_row_table>
