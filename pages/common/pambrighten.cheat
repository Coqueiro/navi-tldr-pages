; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pambrighten.md

% pambrighten, common

# Increase the saturation of each pixel by the specified percentage
pambrighten <__s__saturation_> <value_percent> <path_to_image_pam> > <path_to_output_pam>

# Increase the value (from the HSV color space) of each pixel by the specified percentage
pambrighten <__va__value_> <value_percent> <path_to_image_pam> > <path_to_output_pam>
