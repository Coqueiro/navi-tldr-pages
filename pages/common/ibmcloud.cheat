% ibmcloud, common

# Update `ibmcloud` to the latest version
ibmcloud update

# List all available IBM Cloud regions
ibmcloud regions

# Display help
ibmcloud help

# Display help for a subcommand
ibmcloud help <subcommand>

# Display version
ibmcloud version
