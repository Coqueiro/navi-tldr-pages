; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/ip-netconf.md

% ip-netconf, linux

# Show network configuration for all interfaces
ip <_netc_netconf_>

# Show network configuration for a specific interface
ip <_netc_netconf_> <_s_show_> dev <network_interface>

# Show only IPv4 network configuration
ip -4 <_netc_netconf_>

# Show only IPv6 network configuration
ip -6 <_netc_netconf_>
