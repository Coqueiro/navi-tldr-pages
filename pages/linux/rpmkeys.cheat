; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/rpmkeys.md

% rpmkeys, linux

# List all imported RPM keys. Also outputs its Key ID needed for deleting an imported RPM key
sudo rpmkeys --list

# Remove/Delete a previously imported RPM key, given by its 16-Number/Letters Key ID
sudo rpmkeys --delete <5a278d9c_5bbc73cb>

# Import an RPM key of repository
sudo rpmkeys --import <path_to_rpm_key>
