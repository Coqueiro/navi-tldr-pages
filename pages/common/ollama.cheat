; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/ollama.md

% ollama, common

# Start the daemon required to run other commands
ollama serve

# Run a model and chat with it (will automatically download the model if it's not downloaded)
ollama run <model>

# Run a model with a single prompt and thinking turned off
ollama run <model> --think=false "<prompt>"

# List downloaded models
ollama <_ls_list_>

# Pull a specific model
ollama pull <model>

# List running models
ollama ps

# Delete a model
ollama rm <model>

# Create a model from a `Modelfile`
ollama create <new_model_name> <__f___file_> <path_to_Modelfile>
