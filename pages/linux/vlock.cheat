; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/vlock.md

% vlock, linux

# Lock current virtual console session
vlock

# Lock current virtual console session via flag
vlock <__c___current_>

# Lock all virtual console sessions
vlock <__a___all_>

# Display help
vlock <__h___help_>

# Display version
vlock <__v___version_>
