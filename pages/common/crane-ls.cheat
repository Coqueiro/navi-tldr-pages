; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/crane-ls.md

% crane-ls, common

# List the tags
crane ls <repository>

# Print the full image reference
crane ls <repository> --full-ref

# Omit digest tags
crane ls <__o___omit_digest_tags_>

# Display help
crane ls <__h___help_>
