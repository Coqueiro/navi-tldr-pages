; https://github.com/tldr-pages/tldr/blob/master/pages/common/doctl-compute-droplet.md

% doctl-compute-droplet, common

# Create a droplet
doctl compute <_d_droplet_> <_c_create_> --region <region> --image <os_image> --size <vps_type> <droplet_name>

# Delete a droplet
doctl compute <_d_droplet_> <_d_delete_> <droplet_id_droplet_name>

# List droplets
doctl compute <_d_droplet_> <_ls_list_>
