; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/doctl-kubernetes-options.md

% doctl-kubernetes-options, common

# List regions that support Kubernetes clusters
doctl <_k_kubernetes_> <_o_options_> <_r_regions_>

# List machine sizes that can be used in a Kubernetes cluster
doctl <_k_kubernetes_> <_o_options_> <_s_sizes_>

# List Kubernetes versions that can be used with DigitalOcean clusters
doctl <_k_kubernetes_> <_o_options_> <_v_versions_>
