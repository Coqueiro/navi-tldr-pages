; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/lslocks.md

% lslocks, linux

# List all local system locks
lslocks

# List locks with defined column headers
lslocks <__o___output_> <PID>,<COMMAND>,<PATH>

# List locks producing a raw output (no columns), and without column headers
lslocks <__r___raw_> <__n___noheadings_>

# List locks by PID input
lslocks <__p___pid_> <PID>

# List locks with JSON output to `stdout`
lslocks <__J___json_>
