; https://github.com/tldr-pages/tldr/blob/master/pages/common/jj-squash.md

% jj-squash, common

# Move all changes from current revision to its parent
jj squash

# Move all changes from given revision to its parent
jj squash <__r___revision_> <revset>

# Move all changes from given revision(s) to given other revision
jj squash <__f___from_> <revsets> <__t___into_> <revset>

# Interactively choose which parts to squash
jj squash <__i___interactive_>
