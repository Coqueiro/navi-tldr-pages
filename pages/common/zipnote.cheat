; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/zipnote.md

% zipnote, common

# View the comments on a Zip archive
zipnote <path_to_file_zip>

# Extract the comments on a Zip archive to a file
zipnote <path_to_file_zip> > <path_to_file_txt>

# Add/Update comments in a Zip archive from a file
zipnote < <path_to_file_txt> -w <path_to_file_zip>
