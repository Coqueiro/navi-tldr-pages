; https://github.com/tldr-pages/tldr/blob/master/pages/common/zeroclaw-skills.md

% zeroclaw-skills, common

# List installed skills
zeroclaw skills list

# Install a skill from a GitHub URL
zeroclaw skills install https://github.com/<user>/<repo>

# Install a skill from a local path
zeroclaw skills install <path_to_skill>

# Remove an installed skill
zeroclaw skills remove <skill_name>

# Display help
zeroclaw skills <__h___help_>
