; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pnmshear.md

% pnmshear, common

# Shear a PNM image by the specified angle
pnmshear <angle> <path_to_input_pnm> > <path_to_output_pnm>

# Specify the color of the background in the sheared image
pnmshear <__b__background_> <blue> <angle> <path_to_input_pnm> > <path_to_output_pnm>

# Do not perform anti-aliasing
pnmshear <__n__noantialias_> <angle> <path_to_input_pnm> > <path_to_output_pnm>
