; https://github.com/tldr-pages/tldr/blob/master/pages/common/dhcpwn.md

% dhcpwn, common

# Flood the network with IP requests
dhcpwn <__i___interface_> <network_interface> flood <__c___count_> <number_of_requests>

# Sniff local DHCP traffic
dhcpwn <__i___interface_> <network_interface> sniff
