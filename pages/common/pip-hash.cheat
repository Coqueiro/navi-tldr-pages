; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pip-hash.md

% pip-hash, common

# Generate hash for a package file
pip hash <path_to_package_whl>

# Generate hash using a specific algorithm
pip hash <__a___algorithm_> <sha256_sha384_sha512____> <path_to_package_whl>

# Generate hashes for multiple files
pip hash {{path/to/package1.whl path/to/package2.whl ...}}

# Generate hash for downloaded archive
pip hash <path_to_package_tar_gz>
