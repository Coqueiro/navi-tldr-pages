; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/rustdoc.md

% rustdoc, common

# Generate documentation from the crate's root
rustdoc <src_lib_rs>

# Pass a name for the project
rustdoc <src_lib_rs> --crate-name <name>

# Generate documentation from Markdown files
rustdoc <path_to_file_md>

# Specify the output directory
rustdoc <src_lib_rs> --out-dir <path_to_output_directory>
