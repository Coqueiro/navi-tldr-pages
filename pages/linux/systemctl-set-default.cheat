; https://github.com/tldr-pages/tldr/blob/master/pages/linux/systemctl-set-default.md

% systemctl-set-default, linux

# Set `systemd`'s default boot mode
systemctl set-default <target_name_target>

# Set `systemd` to boot to GUI mode by default
systemctl set-default graphical.target

# Set `systemd` to boot to CLI mode by default
systemctl set-default multi-user.target
