; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/rasttopnm.md

% rasttopnm, common

# Convert a RAST image to a PNM file
rasttopnm <path_to_input_rast> > <path_to_output_pnm>

# Use the color map indices in the raster if they are color values
rasttopnm <__i__index_> <path_to_input_rast> > <path_to_output_pnm>
