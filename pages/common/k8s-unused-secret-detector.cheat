% k8s-unused-secret-detector, common

# Detect unused secrets
k8s-unused-secret-detector

# Detect unused secrets in a specific namespace
k8s-unused-secret-detector <__n___namespace_> <namespace>

# Delete unused secrets in a specific namespace
k8s-unused-secret-detector <__n___namespace_> <namespace> | kubectl delete secrets <__n___namespace_> <namespace>
