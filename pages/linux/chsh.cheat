; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/chsh.md

% chsh, linux

# Set a specific login shell for the current user interactively
chsh

# List available shells
chsh <__l___list_shells_>

# Set a specific login shell for the current user
chsh <__s___shell_> <path_to_shell>

# Set a login shell for a specific user
sudo chsh <__s___shell_> <path_to_shell> <username>
