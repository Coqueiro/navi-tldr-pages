; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/docker-image-load.md

% docker-image-load, common

# Load a Docker image from `stdin`
docker < <path_to_image_file_tar> {{[load|image load]}}

# Load a Docker image from a specific file
docker {{[load|image load]}} <__i___input_> <path_to_image_file_tar>

# Load a Docker image from a specific file in quiet mode
docker {{[load|image load]}} <__q___quiet_> <__i___input_> <path_to_image_file_tar>
