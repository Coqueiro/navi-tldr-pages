; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pamdeinterlace.md

% pamdeinterlace, common

# Produce an image consisting of the input's even-numbered rows
pamdeinterlace <path_to_image_ppm> > <path_to_output_ppm>

# Produce an image consisting of the input's odd-numbered rows
pamdeinterlace {{[-takeo|-takeodd]}} <path_to_image_ppm> > <path_to_output_ppm>
