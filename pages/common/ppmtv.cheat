; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/ppmtv.md

% ppmtv, common

# Give the PPM image an American TV appearance
ppmtv <dim_factor> <path_to_file_ppm> > <path_to_output_ppm>

# Suppress all informational messages
ppmtv <__q__quiet_>

# Display version
ppmtv <__v__version_>
