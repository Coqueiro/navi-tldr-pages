; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/strings.md

% strings, common

# Print all strings in a binary
strings <path_to_file>

# Limit results to strings at least n characters long
strings <__n___bytes_> <n> <path_to_file>

# Prefix each result with its offset within the file
strings <__t___radix_> d <path_to_file>

# Prefix each result with its offset within the file in hexadecimal
strings <__t___radix_> x <path_to_file>
