; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pnmhistmap.md

% pnmhistmap, common

# Draw a histogram of a PNM image
pnmhistmap <path_to_input_pnm> > <path_to_output_pnm>

# Draw the histogram as dots instead of bars
pnmhistmap <__d__dots_> <path_to_input_pnm> > <path_to_output_pnm>

# Specify the range of intensity values to include
pnmhistmap <__l__lval_> <minval> <__rv__rval_> <maxval> <path_to_input_pnm> > <path_to_output_pnm>
