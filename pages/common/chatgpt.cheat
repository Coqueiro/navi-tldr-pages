; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/chatgpt.md

% chatgpt, common

# Start in chat mode
chatgpt

# Give a prompt to answer to
chatgpt <__p___prompt_> "{{What is the regex to match an email address?}}"

# Start in chat mode using a specific model (default is `gpt-3.5-turbo`)
chatgpt <__m___model_> <gpt_4>

# Start in chat mode with an initial prompt
chatgpt <__i___init_prompt_> "{{You are Rick, from Rick and Morty. Respond to questions using his mannerism and include insulting jokes.}}"

# Pipe the result of a command to `chatgpt` as a prompt
echo "{{How to view running processes on Ubuntu?}}" | chatgpt

# Generate an image using DALL-E
chatgpt <__p___prompt_> "{{image: A white cat}}"
