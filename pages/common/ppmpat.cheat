; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/ppmpat.md

% ppmpat, common

# Produce a PPM file of the specified pattern with the specified dimensions
ppmpat -<gingham2_gingham3_madras_tartan_poles____> <width> <height> > <path_to_file_ppm>

# Produce a PPM file of a camo pattern using the specified colors
ppmpat <__ca__camo_> <__co__color_> <color1_color2____> <width> <height> > <path_to_file_ppm>
