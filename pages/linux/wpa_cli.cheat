; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/wpa_cli.md

% wpa_cli, linux

# Scan for available networks
sudo wpa_cli scan

# Show scan results
sudo wpa_cli scan_results

# Add a network
sudo wpa_cli <_add_n_add_network_> <number>

# Set a network's SSID
sudo wpa_cli <_set_n_set_network_> <number> ssid "<SSID>"

# Enable network
sudo wpa_cli <_en_enable_network_> <number>

# Save config
sudo wpa_cli <_sa_save_config_>
