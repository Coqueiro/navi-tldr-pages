; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pamcrater.md

% pamcrater, common

# Create an image of cratered terrain with the specified dimensions
pamcrater <__h__height_> <height> <__w__width_> <width> > <path_to_output_pam>

# Create an image containing the specified number of craters
pamcrater <__n__number_> <n_craters> > <path_to_output_pam>
