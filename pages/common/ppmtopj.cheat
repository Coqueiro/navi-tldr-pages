; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/ppmtopj.md

% ppmtopj, common

# Convert a PPM file to an HP PaintJet file
ppmtopj <path_to_input_ppm> > <path_to_output_pj>

# Move the image in the x and y direction
ppmtopj <__x__xpos_> <dx> <__y__ypos_> <dy> <path_to_input_ppm> > <path_to_output_pj>

# Explicitly specify a gamma value
ppmtopj <__g__gamma_> <gamma> <path_to_input_ppm> > <path_to_output_pj>
