; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/openclaw-update.md

% openclaw-update, common

# Update to the latest version
openclaw update

# Switch to a specific release channel
openclaw update --channel <stable_beta_dev>

# Display version
openclaw update <__v___version_>

# Display help
openclaw update <__h___help_>
