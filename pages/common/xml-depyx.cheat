; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/xml-depyx.md

% xml-depyx, common

# Convert a PYX (ESIS - ISO 8879) document to XML format
xml <_p2x_depyx_> <path_to_input_pyx_URI> > <path_to_output_xml>

# Convert a PYX document from `stdin` to XML format
cat <path_to_input_pyx> | xml <_p2x_depyx_> > <path_to_output_xml>

# Display help
xml <_p2x_depyx_> --help
