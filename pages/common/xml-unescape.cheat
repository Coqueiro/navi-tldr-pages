; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/xml-unescape.md

% xml-unescape, common

# Unescape special XML characters from a string
xml <_unesc_unescape_> "<_lt_a1_gt_>"

# Unescape special XML characters from `stdin`
echo "<_lt_a1_gt_>" | xml <_unesc_unescape_>

# Display help
xml <_unesc_unescape_> --help
