; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/git-cola.md

% git-cola, common

# Start the GUI
git cola

# Start the GUI in amend mode
git cola --amend

# Prompt for a Git repository. Defaults to the current directory
git cola --prompt

# Open the Git repository at mentioned path
git cola <__r___repo_> <path_to_git_repository>

# Apply the path filter to the status widget
git cola <__s___status_filter_> <filter>
