; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pbmtolj.md

% pbmtolj, common

# Convert a PBM file to an HP LaserJet file
pbmtolj <path_to_input_pbm> > <path_to_output_lj>

# Compress the output file using the specified method
pbmtolj -<packbits_delta_compress> <path_to_input_pbm> > <path_to_output_lj>

# Specify the required resolution
pbmtolj <__r__resolution_> <75_100_150_300_600> <path_to_input_pbm> > <path_to_output_lj>
