; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/grub-mkconfig.md

% grub-mkconfig, linux

# Do a dry run and print the configuration to `stdout`
sudo grub-mkconfig

# Generate the configuration file
sudo grub-mkconfig <__o___output_> <_boot_grub_grub_cfg>

# Display help
grub-mkconfig <__h___help_>
