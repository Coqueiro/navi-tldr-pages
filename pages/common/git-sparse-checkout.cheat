; https://github.com/tldr-pages/tldr/blob/master/pages/common/git-sparse-checkout.md

% git-sparse-checkout, common

# Enable sparse checkout
git sparse-checkout init

# Disable sparse-checkout and restore full repository
git sparse-checkout disable

# Specify which directories (or files) to include
git sparse-checkout set <path_to_directory>

# Add more paths later
git sparse-checkout add <path_to_directory>
