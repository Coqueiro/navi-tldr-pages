; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/zeroclaw.md

% zeroclaw, common

# Initialize workspace and configuration (quick setup)
zeroclaw onboard --api-key <api_key> --provider <openrouter_anthropic_openai____>

# Run the full interactive onboarding wizard
zeroclaw onboard --interactive

# Send a single message to the AI agent
zeroclaw agent <__m___message_> "{{Hello, ZeroClaw!}}"

# Start interactive chat mode
zeroclaw agent

# Start the gateway server (default: 127.0.0.1:8080)
zeroclaw gateway

# Start full autonomous runtime (gateway + channels + heartbeat)
zeroclaw daemon

# Check system status
zeroclaw status

# Run diagnostics
zeroclaw doctor
