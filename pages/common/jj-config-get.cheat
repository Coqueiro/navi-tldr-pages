; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/jj-config-get.md

% jj-config-get, common

# Get the value of a config option
jj config <_g_get_> <name>

# Get the configured user name
jj config <_g_get_> user.name

# Get the configured user email
jj config <_g_get_> user.email

# Get the default revset for the log command
jj config <_g_get_> revsets.log
