; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/nmcli-agent.md

% nmcli-agent, linux

# Register `nmcli` as a secret agent and listen for secret requests
nmcli <_a_agent_> <_s_secret_>

# Register `nmcli` as a polkit agent and listen for authorization requests
nmcli <_a_agent_> <_p_polkit_>

# Register `nmcli` as a secret agent and a polkit agent
nmcli <_a_agent_> <_a_all_>
