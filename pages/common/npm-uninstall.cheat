; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/npm-uninstall.md

% npm-uninstall, common

# Remove a package from the current project
npm <_r_uninstall_> <package_name>

# Remove a package globally
npm <_r_uninstall_> <package_name> <__g___global_>

# Remove multiple packages at once
npm <_r_uninstall_> {{package_name1 package_name2 ...}}
