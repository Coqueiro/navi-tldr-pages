; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/rpicam-still.md

% rpicam-still, linux

# Capture a photo with different encoding
rpicam-still <__e___encoding_> <bmp_png_rgb_yuv420> <__o___output_> <path_to_file__bmp_png_rgb_yuv420_>

# Capture a raw image
rpicam-still <__r___raw_> <__o___output_> <path_to_file_jpg>

# Capture a 100 second exposure image
rpicam-still <__o___output_> <path_to_file_jpg> --shutter 100000
