; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/xvfb-run.md

% xvfb-run, linux

# Run the specified command in a virtual X server
xvfb-run <command>

# Try to get a free server number, if the default (99) is not available
xvfb-run <__a___auto_servernum_> <command>

# Pass arguments to the Xvfb server
xvfb-run <__s___server_args_> "{{-screen 0 1024x768x24}}" <command>
