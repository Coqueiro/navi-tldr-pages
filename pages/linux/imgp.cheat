; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/imgp.md

% imgp, linux

# Convert single images and/or whole directories containing valid image formats
imgp <__x___res_> <1366x1000> <path_to_directory> <path_to_file>

# Scale an image by 75% and overwrite the source image to a target resolution
imgp <__x___res_> <75> z-w <path_to_file>

# Rotate an image clockwise by 90 degrees
imgp <__o___rotate_> <90> <path_to_file>
