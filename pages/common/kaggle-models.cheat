; https://github.com/tldr-pages/tldr/blob/master/pages/common/kaggle-models.md

% kaggle-models, common

# Get a model
kaggle <_m_models_> get "<model_name>"

# List all models
kaggle <_m_models_> list

# Initialize metadata file for model creation
kaggle <_m_models_> init

# Create a new model
kaggle <_m_models_> create

# Delete a model
kaggle <_m_models_> delete "<model_name>"

# Update a model
kaggle <_m_models_> update
