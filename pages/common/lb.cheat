; https://github.com/tldr-pages/tldr/blob/master/pages/common/lb.md

% lb, common

# Make a new draft
lb {{[n|new]}}

# Edit a draft
lb {{[e|edit]}}

# Delete a draft
lb {{[t|trash]}}

# Publish a draft
lb {{[p|publish]}}

# Delete a published post
lb {{[d|delete]}}

# Unpublish a published post to edit it as a draft again
lb {{[r|revise]}}
