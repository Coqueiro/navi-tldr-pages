; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/brew-list.md

% brew-list, common

# List all installed formulae and casks
brew <_ls_list_>

# List files belonging to an installed formula
brew <_ls_list_> <formula>

# List artifacts of a cask
brew <_ls_list_> <cask>

# List only formulae
brew <_ls_list_> --formula

# List only casks
brew <_ls_list_> --cask

# List only pinned formulae
brew <_ls_list_> --pinned
