; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/nmblookup.md

% nmblookup, common

# Find hosts in the local network with SMB shares
nmblookup <__S___status_> '*'

# Find hosts in the local network with SMB shares run by SAMBA
nmblookup <__S___status_> __SAMBA__
