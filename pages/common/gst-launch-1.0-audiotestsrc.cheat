% gst-launch-1.0-audiotestsrc, common

# Generate and play a sine wave
gst-launch-1.0 audiotestsrc ! <autoaudiosink>

# Define what type of wave to generate
gst-launch-1.0 audiotestsrc wave=<sine_square_saw_white_noise_pink_noise_ticks____> ! <autoaudiosink>
