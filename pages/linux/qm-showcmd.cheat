; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/qm-showcmd.md

% qm-showcmd, linux

# Show command-line for a specific virtual machine
qm <_sho_showcmd_> <100>

# Put each option on a new line to enhance human readability
qm <_sho_showcmd_> <100> --pretty <true>

# Fetch configuration values from a specific snapshot
qm <_sho_showcmd_> <100> --snapshot <string>
