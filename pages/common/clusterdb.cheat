; https://github.com/tldr-pages/tldr/blob/master/pages/common/clusterdb.md

% clusterdb, common

# Cluster a specific database
clusterdb <database_name>

# Cluster all databases
clusterdb <__a___all_>

# Cluster a specific table in a database
clusterdb <__t___table_> <table_name> <database_name>
