% gst-launch-1.0-pipewiresink, linux

# Output test video
gst-launch-1.0 videotestsrc ! pipewiresink mode=provide

# Give the PipeWire node a name
gst-launch-1.0 <source> ! pipewiresink client-name=<node_name>
