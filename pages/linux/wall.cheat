; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/wall.md

% wall, linux

# Send a message
wall <message>

# Send a message to users that belong to a specific group
wall <__g___group_> <group_name> <message>

# Send a message from a file
wall <file>

# Send a message with timeout (default 300)
wall <__t___timeout_> <seconds> <file>
