; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/aws-mq.md

% aws-mq, common

# Create a broker
aws mq create-broker --host-instance-type <instance_type> --broker-name <broker_name> --engine-type <ACTIVEMQ_RABBITMQ> <__publicly_accessible___no_publicly_accessible>

# List all brokers
aws mq list-brokers

# Describe a specific broker
aws mq describe-broker --broker-id <broker_id>
