; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/toipe.md

% toipe, common

# Start the typing test with the default wordlist
toipe

# Use a specific wordlist
toipe <__w___wordlist_> <wordlist_name>

# Use a custom wordlist
toipe <__f___file_> <path_to_file>

# Specify the number of words on each test
toipe <__n___num_> <number_of_words>

# Include punctuation
toipe <__p___punctuation_>
