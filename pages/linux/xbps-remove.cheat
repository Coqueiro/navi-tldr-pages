; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/xbps-remove.md

% xbps-remove, linux

# Remove a package
xbps-remove <package>

# Remove a package and its dependencies
xbps-remove <__R___recursive_> <package>

# Remove orphan packages (installed as dependencies but no longer required by any package)
xbps-remove <__o___remove_orphans_>

# Remove obsolete packages from the cache
xbps-remove <__O___clean_cache_>
