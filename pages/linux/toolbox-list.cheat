; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/toolbox-list.md

% toolbox-list, linux

# List all Toolbx containers and images
toolbox list

# List only Toolbx containers
toolbox list <__c___containers_>

# List only Toolbx images
toolbox list <__i___images_>
