; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/aa-disable.md

% aa-disable, linux

# Disable profile
sudo aa-disable {{path/to/profile1 path/to/profile2 ...}}

# Disable profiles in a directory (defaults to `/etc/apparmor.d`)
sudo aa-disable --dir <path_to_profiles>
