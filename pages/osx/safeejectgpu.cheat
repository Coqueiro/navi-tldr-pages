; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/osx/safeejectgpu.md

% safeejectgpu, osx

# Eject all GPUs
SafeEjectGPU Eject

# List all GPUs attached
SafeEjectGPU gpus

# List apps using a GPU
SafeEjectGPU gpuid <gpu_id> apps

# Get the status of a GPU
SafeEjectGPU gpuid <gpu_id> status

# Eject a GPU
SafeEjectGPU gpuid <gpu_id> Eject

# Launch an app on a GPU
SafeEjectGPU gpuid <gpu_id> LaunchOnGPU <path_to_App_app>
