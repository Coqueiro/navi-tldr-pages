; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/dkms.md

% dkms, linux

# List currently installed modules
dkms status

# Rebuild all modules for the currently running kernel
sudo dkms autoinstall

# Install version 1.2.1 of the acpi_call module for the currently running kernel
sudo dkms install -m <acpi_call> -v <1_2_1>

# Remove version 1.2.1 of the acpi_call module from all kernels
sudo dkms remove -m <acpi_call> -v <1_2_1> --all
