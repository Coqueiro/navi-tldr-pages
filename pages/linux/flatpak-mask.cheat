; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/flatpak-mask.md

% flatpak-mask, linux

# Ignore updates for a specific flatpak
flatpak mask <com_example_app>

# Undo ignore updates
flatpak mask --remove <com_example_app>

# List all currently masked patterns
flatpak mask <__system___user>
