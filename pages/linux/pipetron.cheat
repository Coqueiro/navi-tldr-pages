; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/linux/pipetron.md

% pipetron, linux

# Start daemon specified in config file (defaults to volume daemon if not specified)
pipetron <__d___daemon_>

# Start volume daemon (mirror volume settings)
pipetron <__vd___volume_daemon_>

# Start audio daemon (mirror audio data)
pipetron <__ad___audio_daemon_>
