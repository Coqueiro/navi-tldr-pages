; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/opencode-export.md

% opencode-export, common

# Export a specific session to a file
opencode export <session_id> > <path_to_session>.json

# Export a session interactively (output in `stdout`)
opencode export

# Display help
opencode export <__h___help_>
