; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pomo.md

% pomo, common

# Initialize pomo's database
pomo init

# Start a pomodoro session
pomo start <message>

# Start a pomodoro session with three intervals that last three seconds
pomo start --duration 3s --pomodoros 3 <message>

# List previous tasks
pomo list

# Display help
pomo --help
