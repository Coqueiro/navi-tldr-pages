; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/npm-explain.md

% npm-explain, common

# Explain why a specific package is installed
npm <_why_explain_> <package_name>

# Show explanation in JSON format
npm <_why_explain_> <package_name> --json

# Include peer dependencies in the explanation
npm <_why_explain_> <package_name> --include peer

# Limit explanation depth to 2 levels deep
npm <_why_explain_> <package_name> --depth 2
