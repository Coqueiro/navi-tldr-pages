; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/pamstretch.md

% pamstretch, common

# Scale up a PAM image by an integer factor
pamstretch <n> <path_to_image_pam> > <path_to_output_pam>

# Scale up a PAM image by the specified factors in the horizontal and vertical directions
pamstretch <__x__xscale_> <xn> <__y__yscale_> <yn> <path_to_image_pam> > <path_to_output_pam>
