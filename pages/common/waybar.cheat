; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/waybar.md

% waybar, common

# Start `waybar` with the default configuration and stylesheet
waybar

# Use a different configuration file
waybar <__c___config_> <path_to_config_jsonc>

# Use a different stylesheet file
waybar <__s___style_> <path_to_stylesheet_css>

# Set the logging level
waybar <__l___log_level_> <trace_debug_info_warning_error_critical_off>
