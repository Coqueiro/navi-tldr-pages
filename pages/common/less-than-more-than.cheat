% less-than-more-than, common

# Open a file in a file descriptor for read and write
exec <3><><path_to_file>

# Open a file descriptor to a remote connection
exec <3><>/dev/<tcp>/<remote_host>/<port_number>

# Close a file descriptor
exec <3><>-
