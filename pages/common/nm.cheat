; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/nm.md

% nm, common

# List global (extern) functions in a file (prefixed with T)
nm <__g___extern_only_> <path_to_file_o>

# List only undefined symbols in a file
nm <__u___undefined_only_> <path_to_file_o>

# List all symbols, even debugging symbols
nm <__a___debug_syms_> <path_to_file_o>

# Demangle C++ symbols (make them readable)
nm <__C___demangle_> <path_to_file_o>
