; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/cisco-ios/ip.md

% ip, cisco-ios

# Set the SSH version
ip ssh version <2>

# Set the address of the device (This is done under `interface command`)
ip address <10_0_0_1> <255_255_255_0>

# Set the address to be determined with DHCP (This is done under `interface command`)
ip address dhcp

# Define a domain name
ip domain-name <example_com>
