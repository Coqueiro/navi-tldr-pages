; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/compopt.md

% compopt, common

# Print the completion options for given command
compopt <command>

# Enable or disable a completion option of a command
compopt <_o__o> <option1> <_o__o> <option2> <command>

# Print the options for the currently executing completion
compopt

# Enable or disable a completion option of a command
compopt <_o__o> <option1> <_o__o> <option2>
