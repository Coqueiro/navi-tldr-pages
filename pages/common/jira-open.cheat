; This has been extracted from
; https://github.com/tldr-pages/tldr/blob/master/pages/common/jira-open.md

% jira-open, common

# Open the Jira project in the browser and print the URL
jira open

# Open a specific issue in the browser and print the URL
jira open <issue_id>

# Print the URL without opening in the browser
jira open <issue_id> <__n___no_browser_>

# Display help
jira open <__h___help_>
